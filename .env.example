PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lavirginia_backend?schema=public
JWT_SECRET=cambia-este-secreto

# Validator — API key para consumir el endpoint de validación
VALIDATOR_API_KEY=validator-dev-key

# OpenCode GO — Kimi K2.6 (visión de imágenes)
AI_GATEWAY_URL=https://opencode.ai/zen/go/v1/chat/completions
AI_GATEWAY_API_KEY=PONER_ACA_TU_OPENCODE_KEY
AI_GATEWAY_MODEL=opencode-go/kimi-k2.6
AI_GATEWAY_TIMEOUT_MS=30000   
MAX_IMAGE_SIZE_MB=10

# Seed (solo para npm run seed)
ADMIN_EMAIL=admin@tudominio.com


# Python ML Model
PYTHON_MODEL_URL=http://localhost:8000
PYTHON_MODEL_TIMEOUT_MS=5000  

