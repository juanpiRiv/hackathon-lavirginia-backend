generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleType {
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      RoleType @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  otps Otp[]
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([expiresAt])
}
